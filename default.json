{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:js-app",
    ":preserveSemverRanges",
    "schedule:monthly",
    ":maintainLockFilesMonthly",
    ":combinePatchMinorReleases"
  ],
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "matchDepTypes": [
        "dependencies"
      ],
      "groupName": "Production Dependencies"
    },
    {
      "matchPackageNames": [
        "typescript"
      ],
      "groupName": "TypeScript"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "Github Actions"
    },
    {
      "matchPackageNames": [
        "@*/*eslint*",
        "*eslint*",
        "@*eslint*/*",
        "@prettier/plugin-*",
        "prettier-plugin-*"
      ],
      "groupName": "ESLint Plugins"
    }
  ]
}
